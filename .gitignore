# ─── Environment Variables ────────────────────────────────────────────────────
# NEVER commit real secrets — use .env.example as the template
.env
.env.local
.env.development
.env.production
.env.staging
.env.test
*.env

# ─── Node.js / npm ───────────────────────────────────────────────────────────
