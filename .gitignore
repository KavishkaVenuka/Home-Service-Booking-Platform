dist/
build/
out/
.output/
.cache/
.parcel-cache/
.vite/

# ─── Frontend (Vite / React) ──────────────────────────────────────────────────
frontend/dist/
frontend/.vite/
frontend/build/

# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log
*.log.*

