# ─── Docker ───────────────────────────────────────────────────────────────────
# Keep Dockerfiles and docker-compose.yml tracked
# Ignore any local overrides
docker-compose.override.yml
docker-compose.local.yml

# ─── Terraform ────────────────────────────────────────────────────────────────
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
terraform/terraform.tfvars          # Contains real secrets (passwords, keys)
terraform/crash.log
terraform/override.tf
terraform/override.tf.json
*_override.tf
*_override.tf.json

# ─── GitHub Actions ───────────────────────────────────────────────────────────
# Keep workflow files tracked — ignore any local secrets files
.secrets

